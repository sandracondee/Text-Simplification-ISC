# Example .env for Text-Simplification-ISC
# 
# Choose ONE mode:
# 1. LOCAL_MODE=1 for Ollama (no API keys needed, ignores external providers)
# 2. Leave LOCAL_MODE empty/commented: all configured external providers will be available

# ============================================================================
# MODE 1: LOCAL MODE (Ollama - runs locally without API keys)
# Uncomment to enable LOCAL_MODE. This disables all external providers.
# ============================================================================
# LOCAL_MODE=1
# OLLAMA_MODEL=mistral              # or: neural-chat, qwen2:7b, etc.
# OLLAMA_BASE_URL=http://localhost:11434  # optional, defaults to localhost:11434

# ============================================================================
# MODE 2: EXTERNAL PROVIDERS (all available simultaneously when LOCAL_MODE is not set)
# Configure all providers with their respective API keys below.
# Each simplifier agent can use a different provider.
# ============================================================================

# --- GEMINI (Google Generative AI) ---
GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-1.5-pro  # optional

# --- GROQ (Llama models) ---
GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=llama-3.1-70b-versatile  # optional

# --- MISTRAL ---
MISTRAL_API_KEY=your-mistral-api-key-here
# MISTRAL_MODEL=mistral-large-latest  # optional

# --- DEEPSEEK ---
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_MODEL=deepseek-chat  # optional

# ============================================================================
# PARALLEL DRAFTERS: Assign a provider to each drafter (A, B, C, D)
# ============================================================================
# Each drafter can use a different provider. If not set, defaults are used.
# Valid values: gemini, groq, mistral, deepseek (or ollama if LOCAL_MODE=1)
#
DRAFTER_PROVIDER_A=gemini
DRAFTER_PROVIDER_B=groq
DRAFTER_PROVIDER_C=mistral
DRAFTER_PROVIDER_D=deepseek

# Optional: Override specific models per drafter
DRAFTER_MODEL_A=gemini-1.5-pro
DRAFTER_MODEL_B=llama-3.1-70b-versatile
DRAFTER_MODEL_C=mistral-large-latest
DRAFTER_MODEL_D=deepseek-chat

# ============================================================================
# JUDGE & EDITOR: Use default provider (resolved from LOCAL_MODE or system)
# ============================================================================
# Optional: Override default models for Judge and Editor
# JUDGE_MODEL=gemini-1.5-pro
# EDITOR_MODEL=gemini-1.5-pro