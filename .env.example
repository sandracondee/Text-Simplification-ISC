# Example .env for Text-Simplification-ISC
# Use LOCAL_MODE=1 or LLM_PROVIDER=ollama to run with a local Ollama model.

# Local / Ollama settings
LOCAL_MODE=1
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3.5:9b
# If your Ollama daemon is not at the default URL, set it here (optional):
OLLAMA_BASE_URL=http://localhost:11434

# Gemini / Google settings (used when LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-1.5-pro
GOOGLE_API_KEY=your-google-api-key-here

# Optional tuning
#MAX_ITER=3
#LOG_LEVEL=info
